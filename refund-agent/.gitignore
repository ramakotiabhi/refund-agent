# Secrets -- never commit these
.env
*.env
!.env.example

# Python
__pycache__/
*.pyc
.venv/
venv/

# Generated logs (regenerated at runtime, not part of the repo's source of truth)
backend/logs/*.jsonl
backend/logs/*.json
!backend/logs/.gitkeep

# OS / editor noise
.DS_Store
.vscode/
.idea/

# Node (if frontend is later migrated to Next.js)
node_modules/
.next/
